{
  "name": "reading-vimrc-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo start --android",
    "check": "npm-run-all2 --parallel check:*",
    "check:biome": "biome ci",
    "check:ls-lint": "ls-lint -config ls-lint.yaml",
    "check:package": "sort-package-json --check",
    "check:type": "tsc --noEmit",
    "fmt": "npm-run-all2 --parallel fmt:*",
    "fmt:biome": "biome check --write --unsafe",
    "fmt:package": "sort-package-json",
    "ios": "expo start --ios",
    "start": "expo start",
    "test": "vitest run",
    "web": "expo start --web"
  },
  "dependencies": {
    "expo": "^55.0.9",
    "expo-clipboard": "^55.0.9",
    "expo-constants": "^55.0.9",
    "expo-linking": "^55.0.9",
    "expo-router": "^55.0.8",
    "expo-status-bar": "^55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@ls-lint/ls-lint": "^2.3.1",
    "@tsconfig/strictest": "^2.0.8",
    "@types/react": "^19.2.14",
    "npm-run-all2": "^8.0.4",
    "sort-package-json": "^3.6.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.1"
  },
  "packageManager": "pnpm@10.33.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "onFail": "error"
    }
  }
}
